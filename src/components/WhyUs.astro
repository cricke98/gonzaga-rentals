---
const reasons = [
  {
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>`,
    title: "You reach a person, not a portal",
    body: "No ticketing systems. No chatbots. When something needs attention, you call or text Tom or Linda directly. Most issues are resolved same day."
  },
  {
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
    title: "Move-in ready, always",
    body: "Every property is inspected and serviced before your first day. Clean carpets, working appliances, fresh paint where needed. No surprises when you open the door."
  },
  {
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>`,
    title: "We know every block",
    body: "All our properties are within a mile of Gonzaga's campus. We know which blocks are quiet, which are close to the bus line, and which are worth the extra few minutes of walking."
  },
  {
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
    title: "Straightforward leases",
    body: "Our lease is plain English. We explain what's in it before you sign. No buried fees, no automatic renewal traps, no penalty clauses designed to confuse you."
  },
  {
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Fair pricing, no games",
    body: "Our rents are competitive for the neighborhood. We don't inflate for students or lower for vacancy. The price you see is the price we stick to."
  },
  {
    icon: `<svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z"/></svg>`,
    title: "Tenants who come back",
    body: "Many of our tenants have renewed three, four, even five years in a row. Some started as students and stayed on after graduation. That doesn't happen by accident."
  },
];
---

<section id="why-us" class="py-24 bg-[#ede7dc]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-16 max-w-xl">
      <p class="text-xs font-medium tracking-[0.25em] uppercase text-[#b5541c] mb-4">Why Gonzaga Rentals</p>
      <h2 class="text-4xl md:text-5xl font-light text-[#2a3f50] leading-tight" style="font-family: 'Fraunces', serif;">
        What makes us<br/><em>different.</em>
      </h2>
      <p class="mt-4 text-[#5a6b70]">Not a checklist. Just the things that matter when you're choosing where to live for a year.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {reasons.map(r => (
        <div class="group">
          <div class="w-12 h-12 flex items-center justify-center text-[#3d5a6e] mb-5 border border-[#c8d8e0] group-hover:bg-[#3d5a6e] group-hover:text-[#f7f3ee] group-hover:border-[#3d5a6e] transition-colors duration-200" set:html={r.icon}></div>
          <h3 class="text-lg font-medium text-[#2a3f50] mb-3" style="font-family: 'Fraunces', serif;">{r.title}</h3>
          <p class="text-sm text-[#5a6b70] leading-relaxed">{r.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
