---
---
<section id="contact" class="py-24 bg-[#3d5a6e]">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-start">

    <div>
      <p class="text-xs font-medium tracking-[0.25em] uppercase text-[#b5541c] mb-6">Get in Touch</p>
      <h2 class="text-4xl md:text-5xl font-light text-[#f7f3ee] leading-tight mb-8" style="font-family: 'Fraunces', serif;">
        Let's find you<br/><em class="text-[#ede7dc]">the right place.</em>
      </h2>
      <p class="text-[#c8d8e0] leading-relaxed mb-10">
        Tell us what you're looking for and we'll get back to you within one business day. No form letters. You'll hear from Tom or Linda directly.
      </p>

      <div class="space-y-5">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-[#2a3f50] flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="18" height="18" fill="none" stroke="#c8d8e0" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </div>
          <div>
            <p class="text-[#f7f3ee] font-medium text-sm mb-1">Email</p>
            <p class="text-[#c8d8e0]">guhouses@gmail.com</p>
            <p class="text-[#9ab0bc] text-xs mt-1">Usually replied to within a few hours</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-10 h-10 bg-[#2a3f50] flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg width="18" height="18" fill="none" stroke="#c8d8e0" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
          </div>
          <div>
            <p class="text-[#f7f3ee] font-medium text-sm mb-1">Location</p>
            <p class="text-[#c8d8e0]">East Spokane, WA 99202</p>
            <p class="text-[#9ab0bc] text-xs mt-1">All properties within 1 mile of GU campus</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="bg-[#f7f3ee] p-8">
      <h3 class="text-xl font-medium text-[#2a3f50] mb-6" style="font-family: 'Fraunces', serif;">Send Us a Message</h3>
      <form class="space-y-5" onsubmit="handleSubmit(event)">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs tracking-wide text-[#5a6b70] uppercase mb-2">First Name</label>
            <input type="text" name="first" required class="w-full border border-[#c8d8e0] bg-white px-4 py-3 text-sm text-[#2c2c2c] focus:outline-none focus:border-[#3d5a6e] transition-colors" placeholder="First"/>
          </div>
          <div>
            <label class="block text-xs tracking-wide text-[#5a6b70] uppercase mb-2">Last Name</label>
            <input type="text" name="last" required class="w-full border border-[#c8d8e0] bg-white px-4 py-3 text-sm text-[#2c2c2c] focus:outline-none focus:border-[#3d5a6e] transition-colors" placeholder="Last"/>
          </div>
        </div>

        <div>
          <label class="block text-xs tracking-wide text-[#5a6b70] uppercase mb-2">Email</label>
          <input type="email" name="email" required class="w-full border border-[#c8d8e0] bg-white px-4 py-3 text-sm text-[#2c2c2c] focus:outline-none focus:border-[#3d5a6e] transition-colors" placeholder="your@email.com"/>
        </div>

        <div>
          <label class="block text-xs tracking-wide text-[#5a6b70] uppercase mb-2">I'm interested in</label>
          <select name="interest" class="w-full border border-[#c8d8e0] bg-white px-4 py-3 text-sm text-[#2c2c2c] focus:outline-none focus:border-[#3d5a6e] transition-colors">
            <option>A specific listed property</option>
            <option>Any available 1-bedroom</option>
            <option>Any available 2-bedroom</option>
            <option>Any available 3+ bedroom</option>
            <option>Something not listed yet</option>
          </select>
        </div>

        <div>
          <label class="block text-xs tracking-wide text-[#5a6b70] uppercase mb-2">Move-in timeline</label>
          <select name="timeline" class="w-full border border-[#c8d8e0] bg-white px-4 py-3 text-sm text-[#2c2c2c] focus:outline-none focus:border-[#3d5a6e] transition-colors">
            <option>As soon as possible</option>
            <option>June 2025</option>
            <option>July 2025</option>
            <option>August 2025</option>
            <option>Fall semester 2025</option>
            <option>Just exploring for now</option>
          </select>
        </div>

        <div>
          <label class="block text-xs tracking-wide text-[#5a6b70] uppercase mb-2">Message</label>
          <textarea name="message" rows="4" class="w-full border border-[#c8d8e0] bg-white px-4 py-3 text-sm text-[#2c2c2c] focus:outline-none focus:border-[#3d5a6e] transition-colors resize-none" placeholder="Tell us a bit about what you need — bedrooms, budget, any questions about specific properties..."></textarea>
        </div>

        <button type="submit" class="w-full bg-[#b5541c] text-[#f7f3ee] py-4 text-sm font-medium tracking-wide hover:bg-[#c96a30] transition-colors">
          Send Message
        </button>
        <p class="text-xs text-[#9ab0bc] text-center">We'll reply within one business day.</p>
      </form>
      <div id="form-success" class="hidden text-center py-8">
        <div class="text-[#3d5a6e] text-4xl mb-3" style="font-family: 'Fraunces', serif;">✓</div>
        <p class="text-[#2a3f50] font-medium mb-1">Message sent.</p>
        <p class="text-sm text-[#5a6b70]">Tom or Linda will be in touch soon.</p>
      </div>
    </div>

  </div>
</section>

<script>
  function handleSubmit(e: Event) {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const success = document.getElementById('form-success');
    form.style.display = 'none';
    if (success) success.classList.remove('hidden');
  }
  (window as any).handleSubmit = handleSubmit;
</script>
