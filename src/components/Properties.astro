---
const properties = [
  {
    id: 1,
    name: "402 East Mission",
    type: "4-Bedroom House",
    price: "$3,200/mo",
    beds: "4",
    baths: "2",
    description: "A spacious four-bedroom, two-bathroom home on East Mission — one of the most sought-after streets near Gonzaga's campus. Room for a full house of students or a family that wants to be close to everything the university neighborhood offers.",
    badge: null,
    badgeColor: null,
    photo: "/gonzaga-rentals/images/property-1.jpg",
  },
  {
    id: 2,
    name: "1608 North Astor",
    type: "6-Bedroom House",
    price: "$4,200/mo",
    beds: "6",
    baths: "3",
    description: "A large six-bedroom, three-bathroom home on North Astor. Plenty of space for a big group, with room to spread out across multiple floors. North Astor is a quiet, tree-lined street in the heart of the Gonzaga neighborhood.",
    badge: "Large Group",
    badgeColor: "#3d5a6e",
    photo: "/gonzaga-rentals/images/property-2.jpg",
  },
  {
    id: 3,
    name: "1919 / 1933 / 1945 North Astor",
    type: "6–7 Bedroom Houses",
    price: "$4,900/mo",
    beds: "6–7",
    baths: "3",
    description: "Three homes on the same block of North Astor, each offering six or seven bedrooms and three bathrooms. Ideal for larger groups or students who want to live close to their housemates. Inquire to find out which units are currently available.",
    badge: "Multiple Available",
    badgeColor: "#b5541c",
    photo: null,
  },
];
---

<section id="properties" class="py-24 bg-[#f7f3ee]">
  <div class="max-w-6xl mx-auto px-6">
    <div class="mb-16">
      <p class="text-xs font-medium tracking-[0.25em] uppercase text-[#b5541c] mb-4">Available Rentals</p>
      <h2 class="text-4xl md:text-5xl font-light text-[#2a3f50] leading-tight max-w-xl" style="font-family: 'Fraunces', serif;">
        Real homes.<br/><em>Real addresses.</em>
      </h2>
      <p class="mt-4 text-[#5a7a8e] max-w-lg">All within walking distance of Gonzaga's campus. Email us at <a href="mailto:guhouses@gmail.com" class="text-[#b5541c] hover:underline">guhouses@gmail.com</a> to inquire about any property.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {properties.map(p => (
        <div class="bg-white border border-[#ede7dc] flex flex-col hover:shadow-md transition-shadow duration-200">
          <!-- Property image header -->
          <div class="h-52 bg-[#e8eef2] relative flex items-end p-4 overflow-hidden">
            {p.photo ? (
              <img src={p.photo} alt={p.name} class="absolute inset-0 w-full h-full object-cover" />
            ) : (
              <>
                <div class="absolute inset-0 bg-gradient-to-br from-[#3d5a6e]/20 to-[#2a3f50]/40"></div>
                <svg class="absolute inset-0 w-full h-full opacity-10" viewBox="0 0 300 176" fill="none">
                  <rect x="60" y="80" width="180" height="96" fill="#2a3f50"/>
                  <path d="M40 80 L150 20 L260 80Z" fill="#3d5a6e"/>
                  <rect x="120" y="110" width="40" height="66" fill="#f7f3ee"/>
                  <rect x="80" y="100" width="35" height="35" fill="#f7f3ee" opacity="0.6"/>
                  <rect x="185" y="100" width="35" height="35" fill="#f7f3ee" opacity="0.6"/>
                </svg>
              </>
            )}
            <div class="relative z-10 flex items-end justify-between w-full">
              <span class="text-2xl font-light text-[#f7f3ee] drop-shadow" style="font-family: 'Fraunces', serif;">{p.price}</span>
              {p.badge && (
                <span class="text-[10px] font-medium tracking-widest uppercase px-3 py-1 text-[#f7f3ee]" style={`background-color: ${p.badgeColor};`}>{p.badge}</span>
              )}
            </div>
          </div>

          <div class="p-6 flex flex-col flex-1">
            <div class="mb-1">
              <span class="text-[10px] tracking-widest uppercase text-[#9ab0bc]">{p.type}</span>
            </div>
            <h3 class="text-xl font-medium text-[#2a3f50] mb-3" style="font-family: 'Fraunces', serif;">{p.name}</h3>
            <p class="text-sm text-[#5a6b70] leading-relaxed mb-4 flex-1">{p.description}</p>

            <div class="flex gap-4 mb-5">
              <div class="flex items-center gap-2 text-sm text-[#3d5a6e]">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
                <span>{p.beds} bed</span>
              </div>
              <div class="flex items-center gap-2 text-sm text-[#3d5a6e]">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>{p.baths} bath</span>
              </div>
            </div>

            <div class="pt-4 border-t border-[#ede7dc]">
              <a href="#contact" class="text-sm text-[#b5541c] font-medium hover:underline">Inquire about this property →</a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-sm text-[#5a7a8e] mb-4">Questions about a property? Email us directly.</p>
      <a href="mailto:guhouses@gmail.com" class="inline-block border border-[#3d5a6e] text-[#3d5a6e] px-8 py-3 text-sm tracking-wide hover:bg-[#3d5a6e] hover:text-[#f7f3ee] transition-colors">
        guhouses@gmail.com
      </a>
    </div>
  </div>
</section>
