---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Quality GU Area Home Rentals — Spokane', description = 'Quality homes near Gonzaga University. Real addresses, real prices, real landlords. Email guhouses@gmail.com.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/gonzaga-rentals/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
